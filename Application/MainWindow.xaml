<Window x:Class="DependencyGraphViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Dependency Graph Viewer"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="📂  Open CSV File"
                        Click="OnOpenFile" Padding="16,8" FontSize="14"
                        Background="#2E75B6" Foreground="White" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button DockPanel.Dock="Right" x:Name="ResetViewButton"
                        Content="⟲  Fit All" Click="OnResetView"
                        Padding="12,8" FontSize="13"
                        Background="#5A9BD5" Foreground="White" BorderThickness="0"
                        Cursor="Hand" IsEnabled="False">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button DockPanel.Dock="Right" x:Name="ResetLayoutButton"
                        Content="↻  Reset Layout" Click="OnResetLayout"
                        Padding="12,8" FontSize="13" Margin="0,0,8,0"
                        Background="#5A9BD5" Foreground="White" BorderThickness="0"
                        Cursor="Hand" IsEnabled="False">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock DockPanel.Dock="Left" x:Name="FileNameLabel"
                           Text="No file loaded" VerticalAlignment="Center"
                           Margin="16,0,0,0" FontSize="13" Foreground="#666"/>
            </DockPanel>
        </Border>

        <!-- Graph surface -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <wv2:WebView2 x:Name="GraphWebView" Visibility="Collapsed"/>
                <TextBlock x:Name="PlaceholderText"
                           Text="Open a CSV file to view the dependency graph"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Foreground="#BBB"/>
            </Grid>
        </Border>

        <!-- Timeline slider -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="16,12" Margin="0,12,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="Timeline"
                               FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                    <TextBlock DockPanel.Dock="Right" x:Name="TimestampLabel"
                               Text="—" FontSize="13" Foreground="#666"
                               HorizontalAlignment="Right"/>
                    <TextBlock DockPanel.Dock="Right" x:Name="ActionCountLabel"
                               Text="" FontSize="13" Foreground="#999"
                               HorizontalAlignment="Right" Margin="0,0,20,0"/>
                </DockPanel>

                <!-- Slider row with playback controls -->
                <DockPanel Margin="0,0,0,8">
                    <Button DockPanel.Dock="Left" x:Name="PlayPauseButton"
                            Content="▶" Click="OnPlayPause" Padding="8,4"
                            FontSize="14" Width="36" Height="32"
                            Background="#2E75B6" Foreground="White" BorderThickness="0"
                            Cursor="Hand" IsEnabled="False" Margin="0,0,10,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Slider x:Name="TimeSlider" Minimum="0" Maximum="0"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnSliderValueChanged" IsEnabled="False"
                            VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Speed control -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Speed:"
                               FontSize="12" Foreground="#999" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Button Content="−" Click="OnSpeedDecrease"
                            Width="28" Height="28" FontSize="14"
                            Background="#E0E0E0" Foreground="#333" BorderThickness="0"
                            Cursor="Hand" VerticalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="SpeedLabel"
                               Text="1×" FontSize="13" Foreground="#666"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               TextAlignment="Center" Width="36"
                               Margin="4,0,4,0"/>
                    <Button Content="+" Click="OnSpeedIncrease"
                            Width="28" Height="28" FontSize="14"
                            Background="#E0E0E0" Foreground="#333" BorderThickness="0"
                            Cursor="Hand" VerticalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <TextBlock Text="Highlight Depth:"
                               FontSize="12" Foreground="#999" VerticalAlignment="Center"
                               Margin="24,0,8,0"/>
                    <Button Content="−" Click="OnHighlightDepthDecrease"
                            Width="28" Height="28" FontSize="14"
                            Background="#E0E0E0" Foreground="#333" BorderThickness="0"
                            Cursor="Hand" VerticalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="HighlightDepthLabel"
                               Text="1" FontSize="13" Foreground="#666"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               TextAlignment="Center" Width="36"
                               Margin="4,0,4,0"/>
                    <Button Content="+" Click="OnHighlightDepthIncrease"
                            Width="28" Height="28" FontSize="14"
                            Background="#E0E0E0" Foreground="#333" BorderThickness="0"
                            Cursor="Hand" VerticalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
