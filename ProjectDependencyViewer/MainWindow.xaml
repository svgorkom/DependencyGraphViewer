<Window x:Class="ProjectDependencyViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Project Dependency Viewer"
        Icon="/app.ico"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F0F2F5"
        StateChanged="OnWindowStateChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E75B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5A9BD5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
        <Style x:Key="SmallControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#19000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1707A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0" Background="#E8EBF0" Padding="0">
            <DockPanel Height="36">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2E75B6"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Project Dependency Viewer" FontSize="12" Foreground="#333"
                               FontFamily="Segoe UI" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#E8F0FE" CornerRadius="8" Padding="8,2" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="🤖 AI-Generated" FontSize="10" Foreground="#2E75B6"
                                   FontFamily="Segoe UI" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#xE921;" Click="OnMinimize" Style="{StaticResource CaptionButtonStyle}"/>
                    <Button x:Name="MaxRestoreButton" Content="&#xE922;" Click="OnMaximizeRestore" Style="{StaticResource CaptionButtonStyle}"/>
                    <Button Content="&#xE8BB;" Click="OnClose" Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>
                <Border/>
            </DockPanel>
        </Border>

        <!-- Header bar -->
        <Border Grid.Row="1" Background="White" CornerRadius="0,0,8,8" Padding="16,12" Margin="16,0,16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="📂  Select Folder"
                        Click="OnSelectFolder" Padding="16,8" FontSize="14"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button DockPanel.Dock="Right" x:Name="ResetViewButton"
                        Content="⟲  Fit All" Click="OnResetView"
                        Padding="12,8" FontSize="13"
                        Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False"/>
                <Button DockPanel.Dock="Right" x:Name="ResetLayoutButton"
                        Content="↻  Reset Layout" Click="OnResetLayout"
                        Padding="12,8" FontSize="13" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False"/>
                <TextBlock DockPanel.Dock="Left" x:Name="FolderPathLabel"
                           Text="No folder selected" VerticalAlignment="Center"
                           Margin="16,0,0,0" FontSize="13" Foreground="#666"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Row="2" Margin="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="150" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: filters + node list -->
            <Grid Grid.Column="0" Margin="0,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filters panel -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Filters" FontWeight="SemiBold" FontSize="14"
                                   Foreground="#333" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="14" Height="14" CornerRadius="3" Background="#27AE60"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <CheckBox x:Name="ShowProjectsCheckBox" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OnFilterChanged" Unchecked="OnFilterChanged">
                                <TextBlock x:Name="ProjectsFilterLabel" Text="Projects" FontSize="12"/>
                            </CheckBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="14" Height="14" CornerRadius="3" Background="#2E75B6"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <CheckBox x:Name="ShowNuGetCheckBox" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OnFilterChanged" Unchecked="OnFilterChanged">
                                <TextBlock x:Name="NuGetFilterLabel" Text="NuGet Packages" FontSize="12"/>
                            </CheckBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="14" Height="14" CornerRadius="3" Background="#E67E22"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <CheckBox x:Name="ShowDllCheckBox" IsChecked="True" VerticalAlignment="Center"
                                      Checked="OnFilterChanged" Unchecked="OnFilterChanged">
                                <TextBlock x:Name="DllFilterLabel" Text="DLL References" FontSize="12"/>
                            </CheckBox>
                        </StackPanel>

                        <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="0,8,0,6"/>

                        <TextBlock Text="Exclude (wildcard patterns)"
                                   FontSize="11" Foreground="#999" Margin="0,0,0,4"/>
                        <DockPanel Margin="0,0,0,4">
                            <Button DockPanel.Dock="Right" Content="+" Click="OnAddExcludeFilter"
                                    Style="{StaticResource SmallControlButtonStyle}"
                                    Width="24" Height="24" Margin="4,0,0,0"
                                    ToolTip="Add exclude pattern"/>
                            <Border Padding="6,4" Background="#F5F6F8" CornerRadius="6"
                                    BorderBrush="#DDD" BorderThickness="1">
                                <TextBox x:Name="ExcludeFilterInput" BorderThickness="0" Background="Transparent"
                                         FontSize="12" Foreground="#333"
                                         KeyDown="OnExcludeFilterKeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="e.g. *Test*"
                                                                               FontSize="11" Foreground="#AAA" Margin="2,0,0,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Border>
                        </DockPanel>
                        <ItemsControl x:Name="ExcludeFilterList">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F0F2F5" CornerRadius="4" Padding="6,3" Margin="0,0,0,2">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="×" Click="OnRemoveExcludeFilter"
                                                    Tag="{Binding}" FontSize="12" Foreground="#999"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Padding="4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding}" FontSize="11" Foreground="#555"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Node list panel -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Nodes" FontWeight="SemiBold" FontSize="14"
                                   Foreground="#333" Margin="12,10,12,8"/>
                        <Border DockPanel.Dock="Top" Margin="8,0,8,8" Padding="8,6"
                                Background="#F5F6F8" CornerRadius="6" BorderBrush="#DDD" BorderThickness="1">
                            <TextBox x:Name="NodeSearchBox" BorderThickness="0" Background="Transparent"
                                     FontSize="12" Foreground="#333"
                                     TextChanged="OnNodeSearchTextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="🔍 Search nodes (* = any, ? = single)"
                                                                           FontSize="11" Foreground="#AAA" Margin="2,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                        <TextBlock DockPanel.Dock="Bottom" x:Name="NodeCountLabel"
                                   Text="" FontSize="11" Foreground="#999"
                                   Margin="12,4,12,8" HorizontalAlignment="Left"/>
                        <ListBox x:Name="NodeListBox" Margin="4,0,4,0"
                                 BorderThickness="0" Background="Transparent"
                                 SelectionChanged="OnNodeListSelectionChanged"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <!-- Graph viewport -->
            <Grid Grid.Column="2">
                <!-- Shadow layer (separate from WebView2 to avoid Effect/HWND conflict) -->
                <Border Background="White" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                </Border>
                <!-- Content layer with WebView2 -->
                <Border Background="White" CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <wv2:WebView2 x:Name="GraphWebView" Visibility="Collapsed"
                                      DefaultBackgroundColor="White"/>
                        <TextBlock x:Name="PlaceholderText"
                                   Text="Select a folder to view the project dependency graph"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="16" Foreground="#BBB"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Controls bar -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="16,10" Margin="16,12,16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Highlight Depth:"
                           FontSize="12" Foreground="#999" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button Content="−" Click="OnHighlightDepthDecrease"
                        Style="{StaticResource SmallControlButtonStyle}"/>
                <TextBlock x:Name="HighlightDepthLabel"
                           Text="1" FontSize="13" Foreground="#666"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           TextAlignment="Center" Width="36"
                           Margin="4,0,4,0"/>
                <Button Content="+" Click="OnHighlightDepthIncrease"
                        Style="{StaticResource SmallControlButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- AI disclaimer footer -->
        <Border Grid.Row="4" Background="#E8EBF0" Padding="0,6">
            <TextBlock Text="🤖 This application was generated with AI assistance. Verify outputs independently."
                       FontSize="11" Foreground="#888" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
